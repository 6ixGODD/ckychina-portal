{
  "name": "ckychina-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prepare": "husky install",
    "preview": "serve out -l 3000",
    "preview:build": "pnpm run build && pnpm run preview",
    "oss:config": "ossutil config -c .ossutilconfig",
    "oss:ls": "ossutil -c .ossutilconfig ls oss://ckychina-portal",
    "oss:cp": "ossutil -c .ossutilconfig cp out/ oss://ckychina-portal --recursive -f",
    "oss:sync": "ossutil -c .ossutilconfig sync out/ oss://ckychina-portal --delete -f",
    "oss:rm": "ossutil -c .ossutilconfig rm oss://ckychina-portal --recursive -f",
    "deploy": "pnpm run build && pnpm run oss:sync"
  },
  "dependencies": {
    "aos": "^2.3.4",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "glightbox": "^3.3.1",
    "imagesloaded": "^5.0.0",
    "isotope-layout": "^3.0.6",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-countup": "^6.5.3",
    "react-dom": "19.2.4",
    "sass": "^1.99.0",
    "swiper": "^12.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@next/eslint-plugin-next": "^16.2.3",
    "@tailwindcss/postcss": "^4",
    "@types/aos": "^3.0.7",
    "@types/bootstrap": "^5.2.10",
    "@types/imagesloaded": "^4.1.7",
    "@types/isotope-layout": "^3.0.15",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.5.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "serve": "^14.2.6",
    "typescript": "^5",
    "typescript-eslint": "^8.58.2"
  },
  "lint-staged": {
    "**/*": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ]
  }
}
